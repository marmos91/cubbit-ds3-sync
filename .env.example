# Copy to .env and fill in values for running integration tests locally.
# .env is gitignored — never commit real credentials.
DS3_TEST_EMAIL=your-email@cubbit.io
DS3_TEST_PASSWORD=your-password
DS3_TEST_BUCKET=your-test-bucket
# Optional:
# DS3_TEST_COORDINATOR_URL=https://api.eu00wi.cubbit.services
# DS3_TEST_TENANT=your-tenant
# DS3_TEST_PREFIX=ds3-drive-tests/
